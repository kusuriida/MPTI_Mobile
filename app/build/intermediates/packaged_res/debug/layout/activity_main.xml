<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/cream"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_topbar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/btnMenu"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_topbar_button"
                android:gravity="center"
                android:text="☰"
                android:textColor="@color/brown"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="DadiMadu"
                android:textColor="@color/text_main"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtToolbarUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin"
                    android:textColor="@color/text_main"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtToolbarRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="pemilik"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_banner"
                    android:elevation="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Selamat Datang di"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="DadiMadu"
                            android:textColor="@color/text_main"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtWelcomeName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Kelola usaha madu hari ini"
                            android:textColor="@color/text_muted"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="112dp"
                        android:layout_height="112dp"
                        android:adjustViewBounds="true"
                        android:contentDescription="Logo DadiMadu"
                        android:scaleType="fitCenter"
                        android:src="@drawable/logo_dm" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Overview"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="112dp"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card"
                        android:elevation="2dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍀"
                            android:textSize="22sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Total Pemasukan"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtPemasukan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rp 0"
                            android:textColor="@color/amber_dark"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="112dp"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card"
                        android:elevation="2dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍂"
                            android:textSize="22sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Total Pengeluaran"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtPengeluaran"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rp 0"
                            android:textColor="@color/danger"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_menu_icon"
                        android:gravity="center"
                        android:text="💰"
                        android:textSize="22sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Laba bulan ini"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txtLaba"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textColor="@color/text_main"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:text="Operasional"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/menuTransaksi"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_menu_icon"
                        android:gravity="center"
                        android:text="🧾"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Kasir"
                            android:textColor="@color/text_main"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Kelola transaksi dengan mudah"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="@color/amber_dark"
                        android:textSize="24sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menuProduk"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_menu_icon"
                        android:gravity="center"
                        android:text="📦"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Produk"
                            android:textColor="@color/text_main"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Kelola data madu anda."
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="@color/amber_dark"
                        android:textSize="24sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menuPelanggan"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_menu_icon"
                        android:gravity="center"
                        android:text="👥"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Pelanggan"
                            android:textColor="@color/text_main"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Kelola data pelanggan."
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="@color/amber_dark"
                        android:textSize="24sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menuLaporan"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_menu_icon"
                        android:gravity="center"
                        android:text="📊"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Laporan"
                            android:textColor="@color/text_main"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="Lihat laporan penjualan, keuangan, dan stok."
                            android:textColor="@color/text_muted"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="@color/amber_dark"
                        android:textSize="24sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/sectionLowStock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Peringatan Stok Menipis"
                        android:textColor="@color/text_main"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/lowStockContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="292dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:elevation="12dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/bg_drawer_header"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:adjustViewBounds="true"
                android:contentDescription="Logo DadiMadu"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_dm" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DadiMadu"
                    android:textColor="@color/text_main"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sistem Pencatatan"
                    android:textColor="@color/text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/navBeranda"
                style="@style/DrawerMenuText"
                android:text="🏠  Beranda" />

            <TextView
                android:id="@+id/navTransaksi"
                style="@style/DrawerMenuText"
                android:text="&#129534;  Kasir" />

            <TextView
                android:id="@+id/navProduk"
                style="@style/DrawerMenuText"
                android:text="📦  Produk" />

            <TextView
                android:id="@+id/navPelanggan"
                style="@style/DrawerMenuText"
                android:text="👥  Pelanggan" />

            <TextView
                android:id="@+id/navPembelian"
                style="@style/DrawerMenuText"
                android:text="📦  Pembelian Stok" />

            <TextView
                android:id="@+id/navPengeluaran"
                style="@style/DrawerMenuText"
                android:text="💸  Pengeluaran" />

            <TextView
                android:id="@+id/navLaporan"
                style="@style/DrawerMenuText"
                android:text="📊  Laporan" />

            <TextView
                android:id="@+id/navPengaturan"
                style="@style/DrawerMenuText"
                android:text="⚙️  Pengaturan" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:background="@drawable/bg_logout"
            android:gravity="center"
            android:text="Keluar 🚪"
            android:textColor="@color/danger"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
