<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brown"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingVertical="34dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_login_panel"
            android:elevation="8dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="82dp"
                android:layout_height="82dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_logo_circle"
                android:gravity="center"
                android:text="🐝"
                android:textSize="44sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="Dadi Madu"
                android:textColor="@color/text_main"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="Sistem Pencatatan Bisnis Madu"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_warning_card"
                android:textColor="@color/danger"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Nama Pengguna"
                android:textColor="@color/text_main"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtUsername"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="nama pengguna"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Kata Sandi"
                android:textColor="@color/text_main"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="kata sandi"
                android:inputType="textPassword"
                android:paddingHorizontal="14dp"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_button_amber"
                android:gravity="center"
                android:text="Masuk ke Sistem"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Dadi Madu © 2026 - Lilac Labs"
            android:textColor="@color/cream"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
