<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.lilaclab.dadimadu"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="33" />

    <permission
        android:name="com.lilaclab.dadimadu.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.lilaclab.dadimadu.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.DadiMadu"
        android:usesCleartextTraffic="true" >
        <activity android:name="com.lilaclab.dadimadu.activity.PengaturanActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.LaporanActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.PengeluaranActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.PembelianActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.PelangganActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.TambahProdukActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.ProdukActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.DetailTransaksiActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.TambahTransaksiActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.TransaksiActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.MainActivity" />
        <activity android:name="com.lilaclab.dadimadu.activity.LoginActivity" />
        <activity
            android:name="com.lilaclab.dadimadu.activity.SplashActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="androidx.room.MultiInstanceInvalidationService"
            android:directBootAware="true"
            android:exported="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.lilaclab.dadimadu.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>

</manifest>